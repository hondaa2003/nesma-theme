<footer class="store-footer bg-[#1A1614] text-[#F5F0E8] pt-16 pb-8">
  <div class="container grid grid-cols-1 lg:grid-cols-4 gap-10">

    <!-- Brand -->
    <div>
      <h2 class="text-2xl font-bold mb-4 tracking-wide text-[#B8955A]">
        {{ store.name }}
      </h2>

      {% if store.description %}
        <p class="text-sm leading-6 opacity-80 mb-6">
          {{ store.description|raw }}
        </p>
      {% endif %}

      <salla-social class="flex gap-4"></salla-social>
    </div>

    <!-- Links -->
    <div>
      <h3 class="mb-4 text-lg font-semibold text-[#B8955A]">
        روابط مهمة
      </h3>
      <salla-menu source="footer"></salla-menu>
    </div>

    <!-- Contacts -->
    <div>
      <h3 class="mb-4 text-lg font-semibold text-[#B8955A]">
        تواصل معنا
      </h3>
      <salla-contacts></salla-contacts>
    </div>

    <!-- Apps + Trust -->
    <div>
      <h3 class="mb-4 text-lg font-semibold text-[#B8955A]">
        حمل التطبيق
      </h3>

      <salla-apps-icons class="mb-6"></salla-apps-icons>

      <salla-trust-badges dark></salla-trust-badges>
    </div>

  </div>

  <!-- Bottom Bar -->
  <div class="container mt-10 pt-6 border-t border-[#B8955A]/20 flex flex-col md:flex-row items-center justify-between gap-4">

    <span class="text-sm opacity-70">
      {% hook copyright %}
    </span>

    <salla-payments></salla-payments>

  </div>
</footer>
